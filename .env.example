APP_NAME="Proyección Social UNAP"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://psec.unap.edu.pe

LOG_CHANNEL=stack
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=psec_db
DB_USERNAME=psec_app
DB_PASSWORD=

CACHE_STORE=file
SESSION_DRIVER=database
QUEUE_CONNECTION=sync

MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=psec@unap.edu.pe
MAIL_FROM_NAME="${APP_NAME}"
